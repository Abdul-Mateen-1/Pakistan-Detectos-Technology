---
/**
 * Categories Index — /categories
 * Simple grid hub (unlike brands/index.astro's rich showcase blocks) since
 * categories.json only has 4 thin entries with no showcase-level content.
 * Primary value here is URL/sitemap completeness — products and brands
 * both already have a hub page, categories was the one gap. In-app
 * discovery is already covered by the homepage's ProductCategoriesSection
 * and the footer nav.
 */
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import Container from "../../components/ui/Container.astro";
import Breadcrumbs from "../../components/layout/Breadcrumbs.astro";
import HelpCTA from "../../components/shared/HelpCTA/HelpCTA.astro";

import categoriesData from "../../data/categories.json";
import products from "../../data/products.json";
import site from "../../data/site.json";

const allCategories = [categoriesData.primary, ...categoriesData.secondary];
const canonicalUrl = "https://metaldetectors.pk/categories";
const metaDescription =
  "Browse every detection equipment category we carry — gold detectors, metal detectors, underground imaging systems, and long range locators.";
---

<Layout title="Categories" description={metaDescription} canonicalUrl={canonicalUrl}>
  <Navbar />
  <main>
    <section class="bg-dark pt-[calc(112px+2.5rem)] pb-14 lg:pb-16">
      <Container>
        <Breadcrumbs items={[{ label: "Categories", href: "/categories" }]} />

        <div class="max-w-2xl mt-2">
          <div class="flex items-center gap-4" data-reveal="up">
            <span class="w-10 h-[2px] bg-primary eyebrow-line" aria-hidden="true"></span>
            <span class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary">Shop by Category</span>
          </div>
          <h1 class="mt-4 font-display text-[32px] sm:text-4xl lg:text-[44px] leading-[1.1] tracking-tight text-text-primary" data-reveal="heading">
            Detection Equipment Categories
          </h1>
          <p class="mt-4 text-sm sm:text-[15px] text-text-secondary leading-relaxed" data-reveal="up">
            {products.length} products across {allCategories.length} categories, from dedicated gold detectors to underground imaging systems.
          </p>
        </div>
      </Container>
    </section>

    <section class="bg-dark pb-16 lg:pb-20 border-t border-dark-border pt-14 lg:pt-16">
      <Container>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {allCategories.map((cat, i) => (
            <a
              href={`/categories/${cat.slug}`}
              aria-label={`${cat.name} — view products`}
              class="group flex flex-col p-6 rounded-xl bg-dark-card border border-dark-border transition-all duration-200 hover:-translate-y-1 hover:border-primary/40"
              data-reveal="up"
              style={`transition-delay: ${i * 80}ms;`}
            >
              <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-dark-surface border border-dark-border text-primary text-lg" aria-hidden="true">
                {"icon" in cat && cat.icon ? cat.icon : cat.name.charAt(0)}
              </div>
              <h2 class="mt-4 text-base font-semibold text-text-primary">{cat.name}</h2>
              <p class="mt-1 text-xs text-text-muted">{cat.count} products</p>
              <p class="mt-3 text-xs text-text-secondary leading-relaxed line-clamp-3 flex-1">{cat.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-primary group-hover:text-primary-hover transition-colors duration-200">
                View Products →
              </span>
            </a>
          ))}
        </div>
      </Container>
    </section>

    <Container>
      <HelpCTA
        eyebrow="Not Sure Which Category Fits?"
        heading="Let Us Help You Choose"
        description="Tell us what you're searching for and where, and our specialists can point you to the right category and model."
        primaryLabel="Browse All Products"
        primaryHref="/products"
        whatsappUrl={site.contact.whatsapp}
      />
    </Container>
  </main>
  <Footer />

  <script>
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    document.querySelectorAll("[data-reveal]").forEach((el) => obs.observe(el));
  </script>
</Layout>
