---
/**
 * Brand Route — /brands/[slug]
 * Statically generated per brand from brands.json.
 * Pre-filter applied on load. Unique intro copy per brand.
 */
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import Container from "../../components/ui/Container.astro";

import CatalogHeader from "../../features/products/Header/CatalogHeader.astro";
import FilterSidebar from "../../features/products/FilterSidebar/FilterSidebar.astro";
import FilterDrawer from "../../features/products/FilterDrawer/FilterDrawer.astro";
import ActiveFilters from "../../features/products/ActiveFilters/ActiveFilters.astro";
import ProductGrid from "../../features/products/ProductGrid/ProductGrid.astro";
import EmptyState from "../../features/products/ProductGrid/EmptyState.astro";
import Pagination from "../../components/shared/Pagination/Pagination.astro";
import CatalogController from "../../features/products/CatalogController.astro";

import brands from "../../data/brands.json";
import products from "../../data/products.json";

export async function getStaticPaths() {
  return brands.map((brand) => ({
    params: { slug: brand.slug },
    props: { brandName: brand.name },
  }));
}

const { slug } = Astro.params;
const { brandName } = Astro.props;

const brandInfo = brands.find((b) => b.slug === slug);
const meta = brandInfo
  ? { intro: brandInfo.description, metaDescription: brandInfo.metaDescription }
  : {
      intro: `Browse the ${brandName} product range from an authorized Pakistani distributor.`,
      metaDescription: `${brandName} detectors available in Pakistan.`,
    };

const title = `${brandName} Detectors`;
const totalCount = products.filter((p) => p.brand === brandName).length;
const canonicalUrl = `https://metaldetectors.pk/brands/${slug}`;
const ogImage = brandInfo?.showcase?.image ?? brandInfo?.logo;
---

<Layout title={title} description={meta.metaDescription} canonicalUrl={canonicalUrl} ogImage={ogImage} noindex={true}>
  <Navbar />
  <main>
    <CatalogHeader
      title={title}
      intro={meta.intro}
      breadcrumbs={[
        { label: "Brands", href: "/brands" },
        { label: brandName, href: `/brands/${slug}` },
      ]}
      totalCount={totalCount}
    />
    <ActiveFilters totalCount={totalCount} />

    <Container class="py-10 lg:py-14">
      <div class="flex gap-8 lg:gap-12">
        <FilterSidebar selectedBrand={slug as string} />
        <div class="flex-1 min-w-0">
          <ProductGrid />
          <EmptyState />
          <Pagination />
        </div>
      </div>
    </Container>

    <FilterDrawer totalCount={totalCount} selectedBrand={slug as string} />
    <div class="lg:hidden h-16" aria-hidden="true"></div>

    <CatalogController initialBrand={slug as string} />
  </main>
  <Footer />

  <script>
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    document.querySelectorAll("[data-reveal]").forEach((el) => obs.observe(el));
  </script>
</Layout>
