---
/**
 * Home Page — Pakistan Detectors Technology
 * Assembles all 12 homepage sections in the order specified
 * by the design brief. Visual rhythm alternates dark/light backgrounds.
 *
 * Section Order:
 * 00. Navbar (persistent)
 * 01. Hero (dark)
 * 02. Trusted Brands (dark)
 * 03. Featured Products (light #F8F6F1)
 * 04. Product Categories (dark #1E1E1A)
 * 05. Why Choose Us (light #F8F6F1)
 * 06. Manufacturer Showcase (dark)
 * 07. How It Works (dark)
 * 08. Testimonials (light #F8F6F1)
 * 09. Company Statistics (dark)
 * 10. Latest Articles (dark)
 * 11. Closing CTA (dark gradient)
 * 12. Footer (darkest #111)
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../features/home/Hero/Hero.astro';
import TrustedBrandsSection from '../features/home/TrustedBrands/TrustedBrandsSection.astro';
import FeaturedProductsSection from '../features/home/FeaturedProducts/FeaturedProductsSection.astro';
import ProductCategoriesSection from '../features/home/ProductCategories/ProductCategoriesSection.astro';
import WhyChooseUsSection from '../features/home/WhyChooseUs/WhyChooseUsSection.astro';
import ManufacturerShowcaseSection from '../components/shared/ManufacturerShowcase/ManufacturerShowcaseSection.astro';
import HowItWorksSection from '../features/home/HowItWorks/HowItWorksSection.astro';
import TestimonialsSection from '../components/shared/Testimonials/TestimonialsSection.astro';
import CompanyStatsSection from '../components/shared/CompanyStats/CompanyStatsSection.astro';
import LatestArticlesSection from '../features/home/LatestArticles/LatestArticlesSection.astro';
import ClosingCTASection from '../features/home/ClosingCTA/ClosingCTASection.astro';
---

<Layout
  title="Home"
  description="Pakistan's premier authorized distributor of gold detectors, underground imaging systems, and metal detection equipment. Shop Nokta, Minelab, and GoldXtra with expert support and nationwide delivery."
  canonicalUrl="https://metaldetectors.pk/"
>
  <Navbar />
  <main>
    <Hero />
    <TrustedBrandsSection />
    <FeaturedProductsSection />
    <ProductCategoriesSection />
    <WhyChooseUsSection />
    <ManufacturerShowcaseSection />
    <HowItWorksSection />
    <TestimonialsSection heading="Trusted by Professionals Across Pakistan" />
    <CompanyStatsSection />
    <LatestArticlesSection />
    <ClosingCTASection />
  </main>
  <Footer />
</Layout>
