---
/**
 * AuthorizedBadge Component
 * Glassmorphism card showing authorized distributor status with brand logos.
 */
const { class: className = "" } = Astro.props;
const brands = ["Nokta", "Minelab", "GoldXtra"];
---

<div
  class:list={[
    "flex items-center gap-3 bg-dark-card/60 backdrop-blur-md rounded-lg px-5 py-3.5 border border-dark-border/50 shadow-lg",
    className,
  ]}
>
  <div
    class="flex items-center justify-center w-9 h-9 rounded-md bg-primary/15 text-primary shrink-0"
    aria-hidden="true"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      <polyline points="9 12 11 14 15 10" />
    </svg>
  </div>
  <div>
    <p class="text-sm font-semibold text-text-primary leading-tight">
      Authorized Distributor
    </p>
    <p class="text-xs text-text-muted mt-0.5">
      {brands.join(" · ")}
    </p>
  </div>
</div>
