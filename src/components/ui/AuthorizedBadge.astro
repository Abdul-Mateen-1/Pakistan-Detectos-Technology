---
/**
 * AuthorizedBadge Component
 * Floating badge overlay on the hero image showing authorized distributor status.
 */

const { class: className = "" } = Astro.props;

const brands = ["Minelab", "Nokta", "Garrett", "OKM"];
---

<div
  class:list={[
    "flex items-center gap-3 bg-dark/80 backdrop-blur-sm rounded-lg px-4 py-3 border border-dark-border/50",
    className,
  ]}
>
  <!-- Shield Icon -->
  <div
    class="flex items-center justify-center w-8 h-8 rounded-md bg-primary/15 text-primary shrink-0"
    aria-hidden="true"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
    </svg>
  </div>

  <div>
    <p class="text-sm font-semibold text-text-primary leading-tight">
      Authorized Distributor
    </p>
    <p class="text-xs text-text-muted mt-0.5">
      {brands.join(" · ")}
    </p>
  </div>
</div>
