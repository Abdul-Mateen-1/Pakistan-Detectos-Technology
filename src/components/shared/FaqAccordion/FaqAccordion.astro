---
/**
 * FaqAccordion Component
 * Shared <details>/<summary> accordion — chevron style, matching
 * ProductTabs' FAQ tab and Footer's mobile nav accordion (this is the 4th
 * independent use of that pattern; extracted here instead of copy-pasted).
 * ContactFAQ.astro keeps its own plus/minus variant, left as-is.
 */
interface FaqItemProps {
  question: string;
  answer: string;
  readMoreHref?: string;
  readMoreLabel?: string;
}

interface Props {
  items: FaqItemProps[];
  defaultOpenFirst?: boolean;
}

const { items, defaultOpenFirst = false } = Astro.props;
---

<div class="flex flex-col">
  {items.map((item, i) => (
    <details class="faq-item border-b border-dark-border group" open={defaultOpenFirst && i === 0}>
      <summary class="flex items-center justify-between gap-4 py-5 text-base font-semibold text-text-primary cursor-pointer list-none">
        {item.question}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>
      <div class="pb-5 pr-10">
        <p class="text-sm text-text-secondary leading-relaxed">{item.answer}</p>
        {item.readMoreHref && (
          <a href={item.readMoreHref} class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-primary hover:text-primary-hover transition-colors duration-200">
            {item.readMoreLabel ?? "Read more"} →
          </a>
        )}
      </div>
    </details>
  ))}
</div>
