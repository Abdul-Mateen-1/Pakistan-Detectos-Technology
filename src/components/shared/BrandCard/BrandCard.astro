---
/**
 * BrandCard Component
 * Grid-layout brand card with logo, model count, and explore CTA.
 * Hover: lifts with subtle gold border glow.
 */
interface Props {
  name: string;
  logo?: string;
  initials: string;
  models: number;
  slug: string;
  index: number;
}

const { name, logo, initials, models, slug, index } = Astro.props;
---

<a
  href={`/brands/${slug}`}
  class="brand-card group flex flex-col items-center bg-dark-card rounded-xl border border-dark-border overflow-hidden transition-all duration-[280ms] ease-out hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_8px_26px_rgba(26,26,24,0.09),0_0_14px_rgba(148,116,42,0.08)]"
  data-reveal="up"
  style={`transition-delay: ${index * 80}ms;`}
  aria-label={`${name} — ${models} models available. Explore collection.`}
>
  <!-- Logo -->
  <div class="w-full flex items-center justify-center px-6 py-8 sm:py-10">
    <div class="h-10 sm:h-12 flex items-center justify-center">
      {logo ? (
        <img
          src={logo}
          alt={`${name} logo`}
          class="max-h-full max-w-[140px] object-contain brightness-0 opacity-60 transition-all duration-[280ms] ease-out group-hover:brightness-100 group-hover:opacity-100"
          loading="lazy"
        />
      ) : (
        <div class="flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 rounded-lg bg-dark-surface border border-dark-border text-primary font-display text-sm opacity-80 transition-opacity duration-[280ms] ease-out group-hover:opacity-100">
          {initials}
        </div>
      )}
    </div>
  </div>

  <!-- Divider -->
  <div class="w-full h-px bg-dark-border" aria-hidden="true"></div>

  <!-- Content -->
  <div class="flex flex-col items-center gap-2 px-4 py-4 w-full">
    <h3 class="text-sm sm:text-base font-semibold text-text-primary">{name}</h3>
    <div class="flex items-center gap-1.5">
      <span class="text-lg font-bold text-primary">{models}</span>
      <span class="text-[10px] font-medium uppercase tracking-wider text-text-muted">Models</span>
    </div>
    <span class="text-xs font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      Explore →
    </span>
  </div>
</a>
