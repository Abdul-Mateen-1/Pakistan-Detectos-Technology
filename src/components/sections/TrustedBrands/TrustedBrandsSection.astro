---
/**
 * TrustedBrandsSection Component
 * 4×2 grid of brand cards (not a carousel — grid shows all brands at once).
 * Positioned before Products to establish trust first.
 */
import Container from "../../ui/Container.astro";
import TrustedBrandsHeader from "./TrustedBrandsHeader.astro";
import BrandCard from "./BrandCard.astro";

const brands = [
  { id: 1, name: "Garrett", logo: "https://garrett.com/app/themes/garrett-unified/assets/images/Logo_Garrett.svg", models: 10, slug: "garrett" },
  { id: 2, name: "Nokta", logo: "https://www.noktadetectors.com/wp-content/uploads/2021/04/nokta-footer-logo-1.png", models: 12, slug: "nokta" },
  { id: 3, name: "Minelab", logo: "https://www.minelab.com/media/logo/stores/30/minelab-logo-inverse.svg", models: 15, slug: "minelab" },
  { id: 4, name: "OKM", logo: "/images/brands/okm-logo.svg", models: 8, slug: "okm" },
  { id: 5, name: "Fisher", logo: "/images/brands/fisher-logo.svg", models: 6, slug: "fisher" },
  { id: 6, name: "Teknetics", logo: "/images/brands/teknetics-logo.svg", models: 5, slug: "teknetics" },
  { id: 7, name: "XP", logo: "/images/brands/xp-logo.svg", models: 7, slug: "xp" },
  { id: 8, name: "GoldXtra", logo: "https://goldxtra.com/wp-content/uploads/2023/11/cropped-GOLDXTRAAAALOGOOOvar-1.png", models: 8, slug: "goldxtra" },
];
---

<section
  id="trusted-brands"
  class="relative bg-dark py-[var(--spacing-section)]"
  aria-labelledby="trusted-brands-heading"
>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-dark-border to-transparent pointer-events-none" aria-hidden="true"></div>

  <Container>
    <div class="mb-12 lg:mb-16">
      <TrustedBrandsHeader />
    </div>

    <!-- 4×2 Brand Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 lg:gap-6">
      {brands.map((brand, index) => (
        <BrandCard
          name={brand.name}
          logo={brand.logo}
          models={brand.models}
          slug={brand.slug}
          index={index}
        />
      ))}
    </div>
  </Container>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-dark-border to-transparent pointer-events-none" aria-hidden="true"></div>
</section>

<script>
  const brandsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          brandsObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );
  document.querySelectorAll("#trusted-brands [data-reveal]").forEach((el) => brandsObserver.observe(el));
</script>
