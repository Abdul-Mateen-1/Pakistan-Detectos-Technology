---
/**
 * TrustedBrandsHeader Component
 * Section header with eyebrow label, main heading, and supporting paragraph.
 * Uses the same typography hierarchy established by the Hero and FeaturedProducts sections.
 */
---

<!-- Eyebrow -->
<div class="flex items-center gap-4 justify-center" data-reveal="up">
  <span class="w-10 h-[2px] bg-primary" aria-hidden="true"></span>
  <span
    class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary"
  >
    Trusted Brands
  </span>
  <span class="w-10 h-[2px] bg-primary" aria-hidden="true"></span>
</div>

<!-- Main Heading -->
<h2
  class="mt-4 font-display text-4xl sm:text-5xl font-bold leading-[1.1] tracking-tight text-text-primary text-center"
  data-reveal="up"
>
  World-Class Manufacturers
</h2>

<!-- Supporting Description -->
<p
  class="mt-4 text-sm sm:text-base text-text-muted leading-relaxed max-w-xl mx-auto text-center"
  data-reveal="up"
>
  We proudly offer products from the world's leading metal detector
  manufacturers — trusted by professionals across the globe.
</p>
