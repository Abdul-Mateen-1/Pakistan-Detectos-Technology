---
/**
 * TrustedBrandsHeader Component
 * Centered section header with eyebrow, heading, and description.
 */
---

<div class="flex items-center gap-4 justify-center" data-reveal="up">
  <span class="w-10 h-[2px] bg-primary" aria-hidden="true"></span>
  <span class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary">
    Trusted Brands
  </span>
  <span class="w-10 h-[2px] bg-primary" aria-hidden="true"></span>
</div>

<h2
  id="trusted-brands-heading"
  class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.1] tracking-tight text-text-primary text-center"
  data-reveal="up"
>
  World-Class Manufacturers
</h2>

<p class="mt-4 text-sm sm:text-base text-text-muted leading-relaxed max-w-xl mx-auto text-center" data-reveal="up">
  We carry the brands you already trust — authorized distributor for the world's
  leading detection equipment manufacturers.
</p>
