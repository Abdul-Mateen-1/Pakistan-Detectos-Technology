---
/**
 * ActiveFilters Component
 * Sticky row under header: dismissible filter chips + Clear all,
 * live product count, and desktop sort dropdown.
 * Chips populated by catalog script. Mobile sort lives in FilterDrawer bar.
 */
import Container from "../../ui/Container.astro";
import SortDropdown from "./SortDropdown.astro";

interface Props {
  totalCount: number;
}

const { totalCount } = Astro.props;
---

<div
  id="active-filters-bar"
  class="sticky top-[72px] z-[calc(var(--z-navbar)-1)] bg-dark/95 backdrop-blur-xl border-b border-dark-border/60"
>
  <Container>
    <div class="flex items-center justify-between gap-4 py-2.5 min-h-[48px]">
      <!-- Left: chips + clear -->
      <div class="flex-1 flex items-center gap-2 flex-wrap min-w-0">
        <div
          id="active-chips"
          class="flex items-center gap-2 flex-wrap"
          role="list"
          aria-label="Active filters"
        >
          <!-- chips injected here by catalog script -->
        </div>
        <button
          type="button"
          id="chips-clear-all"
          class="hidden text-xs text-text-muted hover:text-primary underline underline-offset-4 transition-colors duration-200"
        >
          Clear all
        </button>
      </div>

      <!-- Right: count + sort (desktop) -->
      <div class="flex items-center gap-4 shrink-0">
        <span class="hidden sm:inline text-xs text-text-muted">
          <span id="active-count" data-total={totalCount}>{totalCount}</span> products
        </span>
        <div class="hidden lg:block">
          <SortDropdown />
        </div>
      </div>
    </div>
  </Container>
</div>

<style is:global>
  /* Chip template — injected dynamically by catalog script */
  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.5rem 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-primary);
    background-color: rgba(197, 160, 68, 0.15);
    border: 1px solid rgba(197, 160, 68, 0.3);
    border-radius: 9999px;
    transition: all 200ms ease-out;
  }
  .filter-chip:hover {
    background-color: rgba(197, 160, 68, 0.22);
  }
  .filter-chip button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 9999px;
    color: rgba(197, 160, 68, 0.7);
    cursor: pointer;
    transition: color 200ms ease-out;
  }
  .filter-chip button:hover {
    color: var(--color-primary);
  }
</style>
