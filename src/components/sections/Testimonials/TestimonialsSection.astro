---
/**
 * TestimonialsSection Component
 * Light background with authentic testimonials.
 * Reads from src/data/testimonials.json.
 */
import Container from "../../ui/Container.astro";

import testimonials from "../../../data/testimonials.json";
---

<section
  id="testimonials"
  class="relative bg-light py-[var(--spacing-section)]"
  aria-labelledby="testimonials-heading"
>
  <Container>
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2
        id="testimonials-heading"
        class="font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.1] tracking-tight text-text-dark"
        data-reveal="up"
      >
        Trusted by Professionals Across Pakistan
      </h2>
    </div>

    <!-- Testimonial Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((t, index) => (
        <blockquote
          class="flex flex-col bg-light-card rounded-xl border border-light-border p-6 lg:p-8 shadow-card-light-section"
          data-reveal="up"
          style={`transition-delay: ${index * 100}ms;`}
        >
          <div class="text-primary text-4xl font-display leading-none mb-3" aria-hidden="true">"</div>
          <p class="text-sm sm:text-base text-text-dark-secondary leading-relaxed flex-1">
            {t.quote}
          </p>
          <div class="flex items-center gap-3 mt-6 pt-5 border-t border-light-border">
            <div class="w-10 h-10 rounded-full bg-dark-card flex items-center justify-center shrink-0">
              <span class="text-xs font-bold text-primary">{t.initials}</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-text-dark">{t.name}</p>
              <p class="text-xs text-text-dark-muted">{t.title} — {t.location}</p>
            </div>
          </div>
        </blockquote>
      ))}
    </div>
  </Container>
</section>

<script>
  const testObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          testObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );
  document.querySelectorAll("#testimonials [data-reveal]").forEach((el) => testObserver.observe(el));
</script>
