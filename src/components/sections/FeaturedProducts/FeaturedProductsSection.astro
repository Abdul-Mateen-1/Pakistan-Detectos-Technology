---
/**
 * FeaturedProductsSection Component
 * Light-background section with 3 curated product cards.
 * Shows spec tags, bestseller badges, and professional pricing.
 */
import Container from "../../ui/Container.astro";
import Button from "../../ui/Button.astro";
import FeaturedProductsHeader from "./FeaturedProductsHeader.astro";
import ProductCard from "./ProductCard.astro";

import noktaGoldKruzerImg from "../../../assets/Nokta-Gold-Racer-4.png";
import noktaImpactProImg from "../../../assets/Nokta_Impace_Pro.png";
import fisherF75Img from "../../../assets/Fisher_F75.png";

const products = [
  {
    id: 1,
    name: "Nokta Gold Kruzer",
    brand: "Nokta",
    price: 295000,
    description: "61 kHz frequency for gold prospecting at its sharpest.",
    image: noktaGoldKruzerImg,
    slug: "nokta-gold-kruzer",
    badge: "Bestseller",
    specs: ["Waterproof", "61 kHz"],
  },
  {
    id: 2,
    name: "OKM eXp 6000",
    brand: "OKM",
    price: null,
    description: "Professional 3D ground scanner with live imaging.",
    image: noktaImpactProImg,
    slug: "okm-exp-6000",
    badge: null,
    specs: ["3D Imaging", "25m Depth"],
  },
  {
    id: 3,
    name: "Garrett ATX",
    brand: "Garrett",
    price: 450000,
    description: "Military-grade pulse induction for extreme conditions.",
    image: fisherF75Img,
    slug: "garrett-atx",
    badge: null,
    specs: ["PI Tech", "Military"],
  },
];
---

<section
  id="featured-products"
  class="relative bg-light py-[var(--spacing-section)]"
  aria-labelledby="featured-heading"
>
  <Container>
    <!-- Header with View All link -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 lg:mb-16">
      <FeaturedProductsHeader />
      <div class="hidden sm:block" data-reveal="up">
        <Button variant="outline-light" size="md" href="/products">
          View All Products
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </Button>
      </div>
    </div>

    <!-- Product Cards - Horizontal scroll on mobile, 3-col grid on desktop -->
    <div class="hidden md:grid md:grid-cols-3 gap-6 lg:gap-8">
      {products.map((product, index) => (
        <ProductCard
          name={product.name}
          brand={product.brand}
          price={product.price}
          description={product.description}
          image={product.image}
          slug={product.slug}
          badge={product.badge}
          specs={product.specs}
          index={index}
        />
      ))}
    </div>

    <!-- Mobile: Horizontal scroll -->
    <div class="md:hidden overflow-x-auto scrollbar-hide -mx-6 px-6 snap-x snap-mandatory">
      <div class="flex gap-4" style="width: max-content;">
        {products.map((product, index) => (
          <div class="w-[85vw] max-w-[340px] snap-center flex-shrink-0">
            <ProductCard
              name={product.name}
              brand={product.brand}
              price={product.price}
              description={product.description}
              image={product.image}
              slug={product.slug}
              badge={product.badge}
              specs={product.specs}
              index={index}
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: View All -->
    <div class="mt-8 sm:hidden flex justify-center" data-reveal="up">
      <Button variant="outline-light" size="lg" href="/products" class="w-full">
        View All Products
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </Button>
    </div>
  </Container>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll("#featured-products [data-reveal]").forEach((el) => observer.observe(el));
</script>
