---
/**
 * ProductCard Component
 * Light-section product card with spec tags, brand badge, and hover effects.
 * Image is a string path (from public/ folder), not ImageMetadata.
 */
interface Props {
  name: string;
  brand: string;
  price: number | null;
  description: string;
  image: string;
  slug: string;
  badge: string | null;
  specs: string[];
  index: number;
}

const { name, brand, price, description, image, slug, badge, specs, index } = Astro.props;
const formattedPrice = price ? price.toLocaleString("en-PK") : null;
---

<article
  class="product-card group flex flex-col h-full bg-light-card rounded-xl border border-light-border shadow-card-light-section overflow-hidden transition-all duration-[280ms] ease-out hover:-translate-y-1 hover:shadow-card-light-section-hover hover:border-primary/30"
  data-reveal="up"
  style={`transition-delay: ${index * 100}ms;`}
>
  <!-- Image Container -->
  <div class="relative p-5 pb-3 overflow-hidden">
    <!-- Brand Badge -->
    <span class="absolute top-3 left-3 z-10 px-3 py-1 text-[10px] font-semibold uppercase tracking-wider text-text-dark-muted bg-light-surface rounded-full border border-light-border">
      {brand}
    </span>

    <!-- Bestseller / New Badge -->
    {badge && (
      <span class="absolute top-3 right-3 z-10 px-3 py-1 text-[10px] font-semibold uppercase tracking-wider text-dark bg-primary rounded-full">
        {badge}
      </span>
    )}

    <!-- Product Image -->
    <div class="aspect-[4/3] flex items-center justify-center rounded-lg bg-light-surface">
      <img
        src={image}
        alt={`${name} by ${brand} — professional detection equipment`}
        width="400"
        height="300"
        class="w-full h-full object-contain transition-transform duration-[280ms] ease-out group-hover:scale-105"
        loading="lazy"
      />
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 px-5 pb-5 pt-2">
    <h3 class="text-lg font-semibold text-text-dark leading-snug">{name}</h3>
    <p class="mt-1.5 text-sm text-text-dark-secondary leading-relaxed">{description}</p>

    <!-- Spec Tags -->
    {specs.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {specs.map((spec) => (
          <span class="px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 rounded-md border border-primary/20">
            {spec}
          </span>
        ))}
      </div>
    )}

    <!-- Price Row -->
    <div class="mt-auto pt-4 flex items-end justify-between gap-4">
      {formattedPrice ? (
        <div class="flex items-baseline gap-1.5">
          <span class="text-[10px] font-semibold uppercase tracking-wider text-text-dark-muted">PKR</span>
          <span class="text-xl font-bold text-primary">{formattedPrice}</span>
        </div>
      ) : (
        <a
          href="/contact"
          class="text-sm font-medium text-text-dark-secondary hover:text-primary transition-colors duration-200"
        >
          Request Quote
        </a>
      )}

      <a
        href={`/products/${slug}`}
        class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary-hover transition-colors duration-200 group-hover:underline"
      >
        View Details
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-[280ms] ease-out group-hover:translate-x-0.5" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </div>
</article>
