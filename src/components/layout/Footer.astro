---
/**
 * Footer Component
 * Reads links from src/data/navigation.json.
 * Reads company info from src/data/site.json.
 */
import Container from "../ui/Container.astro";
import logoIcon from "../../assets/logo-icon.png";

import navigation from "../../data/navigation.json";
import site from "../../data/site.json";

const footerSections = [
  { title: "Products", links: navigation.footer.products },
  { title: "Brands", links: navigation.footer.brands },
  { title: "Company", links: navigation.footer.company },
];
---

<footer class="theme-dark bg-dark-deep pt-16 lg:pt-20 pb-8" role="contentinfo">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 pb-12 border-b border-dark-border">
      <!-- Company Info -->
      <div class="lg:col-span-4">
        <a href="/" class="flex items-center gap-3" aria-label="Pakistan Detectors Technology - Home">
          <img src={logoIcon.src} alt="" width="52" height="46" class="h-12 w-auto object-contain" loading="lazy" />
          <span class="font-display font-semibold leading-[1.15] text-text-primary text-base tracking-tight">
            Pakistan Detectors<br /> Technology
          </span>
        </a>
        <p class="mt-4 text-sm text-text-secondary leading-relaxed max-w-sm">
          {site.description}
        </p>

        <!-- Social Icons (profiles with "#" placeholders are hidden until real URLs land in site.json) -->
        <div class="flex items-center gap-4 mt-6">
          {site.social.facebook !== "#" && <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text-primary transition-colors duration-200" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>}
          {site.social.youtube !== "#" && <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text-primary transition-colors duration-200" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>}
          {site.social.instagram !== "#" && <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text-primary transition-colors duration-200" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>}
          <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="text-whatsapp hover:text-whatsapp-hover transition-colors duration-200" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <!-- Desktop: Link Columns -->
      <div class="hidden lg:grid lg:col-span-5 grid-cols-3 gap-8">
        {footerSections.map((section) => (
          <div>
            <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">{section.title}</h3>
            <ul class="flex flex-col gap-3" role="list">
              {section.links.map((link) => (
                <li><a href={link.href} class="text-sm text-text-secondary hover:text-primary transition-colors duration-200">{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Mobile: Accordion -->
      <div class="lg:hidden flex flex-col gap-0 border-t border-dark-border">
        {footerSections.map((section) => (
          <details class="footer-accordion border-b border-dark-border group">
            <summary class="flex items-center justify-between py-4 text-sm font-semibold text-text-primary uppercase tracking-wider cursor-pointer list-none">
              {section.title}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-open:rotate-180" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
            </summary>
            <ul class="flex flex-col gap-3 pb-4" role="list">
              {section.links.map((link) => (
                <li><a href={link.href} class="text-sm text-text-secondary hover:text-primary transition-colors duration-200">{link.label}</a></li>
              ))}
            </ul>
          </details>
        ))}
      </div>

      <!-- Contact Column -->
      <div class="lg:col-span-3">
        <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Contact</h3>
        <ul class="flex flex-col gap-3 text-sm text-text-secondary" role="list">
          <li>{site.contact.address}</li>
          <li><a href={`tel:${site.contact.phone}`} class="hover:text-primary transition-colors duration-200">{site.contact.phone}</a></li>
          <li><a href={`mailto:${site.contact.email}`} class="hover:text-primary transition-colors duration-200">{site.contact.email}</a></li>
          <li><a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-whatsapp transition-colors duration-200">WhatsApp</a></li>
          <li class="text-text-muted text-xs mt-1">{site.contact.hours}</li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 text-xs text-text-muted">
      <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-text-primary transition-colors duration-200">Privacy Policy</a>
        <span aria-hidden="true">·</span>
        <a href="/terms" class="hover:text-text-primary transition-colors duration-200">Terms</a>
        <span aria-hidden="true">·</span>
        <a href="/sitemap-index.xml" class="hover:text-text-primary transition-colors duration-200">Sitemap</a>
      </div>
    </div>
  </Container>
</footer>
