---
/**
 * BuyBox Component (Product Detail)
 * Category/brand eyebrow, H1, intro, spec pills, price, primary CTAs,
 * share/compare action row, and the 2x2 trust grid.
 */
import Button from "../../components/ui/Button.astro";

interface Props {
  name: string;
  brand: string;
  brandSlug: string;
  categoryLabel: string;
  categorySlug: string;
  price: number | null;
  intro: string;
  specs: string[];
  whatsappUrl: string;
}

const { name, brand, brandSlug, categoryLabel, categorySlug, price, intro, specs, whatsappUrl } = Astro.props;
const formattedPrice = price ? price.toLocaleString("en-PK") : null;

function iconForSpec(spec: string): "bolt" | "droplet" | "scan" | "radar" | "feather" | "shield" | "check" {
  if (/kHz|multi-freq|vlf|pi tech/i.test(spec)) return "bolt";
  if (/water|ip6|depth/i.test(spec)) return "droplet";
  if (/3d|imaging/i.test(spec)) return "scan";
  if (/long range|adjustable|directional/i.test(spec)) return "radar";
  if (/lightweight|portable/i.test(spec)) return "feather";
  if (/military|weatherproof/i.test(spec)) return "shield";
  return "check";
}

const trustItems = [
  { title: "Genuine Product", desc: "100% authentic, authorized stock" },
  { title: "Free Delivery", desc: "Nationwide, insured shipping" },
  { title: "Manufacturer Warranty", desc: "International warranty coverage" },
  { title: "Training Included", desc: "Free product training session" },
];
---

<div>
  <!-- Category > Brand eyebrow -->
  <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.15em]" data-reveal="up">
    <a href={`/categories/${categorySlug}`} class="text-text-muted hover:text-primary transition-colors duration-200">{categoryLabel}</a>
    <span class="text-text-muted" aria-hidden="true">›</span>
    <a href={`/brands/${brandSlug}`} class="text-primary hover:text-primary-hover transition-colors duration-200">{brand}</a>
  </div>

  <!-- H1 -->
  <h1 class="mt-3 font-display text-3xl sm:text-4xl lg:text-[42px] leading-[1.1] tracking-tight text-text-primary" data-reveal="up">
    {name}
  </h1>

  <!-- Intro -->
  <p class="mt-4 text-[15px] sm:text-base text-text-secondary leading-relaxed" data-reveal="up">
    {intro}
  </p>

  <!-- Spec Pills -->
  {specs.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-2.5" data-reveal="up">
      {specs.map((spec) => {
        const icon = iconForSpec(spec);
        return (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-text-secondary bg-dark-card rounded-full border border-dark-border">
            <span class="text-primary" aria-hidden="true">
              {icon === "bolt" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
              )}
              {icon === "droplet" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69s-6 7-6 11a6 6 0 0 0 12 0c0-4-6-11-6-11z" /></svg>
              )}
              {icon === "scan" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2" /></svg>
              )}
              {icon === "radar" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2" /><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-8.49a6 6 0 0 0 0 8.49M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" /></svg>
              )}
              {icon === "feather" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z" /><line x1="16" y1="8" x2="2" y2="22" /><line x1="17.5" y1="15" x2="9" y2="15" /></svg>
              )}
              {icon === "shield" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
              )}
              {icon === "check" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
              )}
            </span>
            {spec}
          </span>
        );
      })}
    </div>
  )}

  <!-- Price -->
  <div class="mt-7 pt-6 border-t border-dark-border" data-reveal="up">
    <span class="text-xs font-semibold uppercase tracking-wider text-text-muted">Price</span>
    {formattedPrice ? (
      <div class="mt-1.5 flex items-baseline gap-2">
        <span class="text-3xl sm:text-4xl font-bold text-primary">PKR {formattedPrice}</span>
        <span class="text-xs text-text-muted">Inclusive of all taxes</span>
      </div>
    ) : (
      <div class="mt-1.5 flex items-baseline gap-2">
        <span class="text-2xl sm:text-3xl font-bold text-text-primary">Request a Quote</span>
        <span class="text-xs text-text-muted">Pricing shared on inquiry</span>
      </div>
    )}
  </div>

  <!-- CTAs -->
  <div class="mt-5 flex flex-col sm:flex-row gap-3" data-reveal="up">
    <Button variant="primary" size="lg" href="/contact" class="flex-1 justify-center">
      Request a Quote
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </Button>
    <Button variant="whatsapp" size="lg" href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="flex-1 justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp Expert
    </Button>
  </div>

  <!-- Share / Compare -->
  <div class="mt-4 flex items-center gap-5" data-reveal="up">
    <button type="button" id="share-product-btn" class="inline-flex items-center gap-1.5 text-xs font-medium text-text-muted hover:text-primary transition-colors duration-200 cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" />
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
      </svg>
      <span id="share-product-label">Share Product</span>
    </button>
    <a href={`/categories/${categorySlug}`} class="inline-flex items-center gap-1.5 text-xs font-medium text-text-muted hover:text-primary transition-colors duration-200">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="8" height="8" rx="1" /><rect x="13" y="13" width="8" height="8" rx="1" />
        <path d="M11 7h6a2 2 0 0 1 2 2v4M13 17H7a2 2 0 0 1-2-2V11" />
      </svg>
      Compare Similar
    </a>
  </div>

  <!-- Trust Grid -->
  <div class="mt-7 grid grid-cols-2 gap-3" data-reveal="up">
    {trustItems.map((item, i) => (
      <div class="flex items-start gap-2.5 p-3.5 rounded-lg bg-dark-card border border-dark-border">
        <span class="text-primary shrink-0 mt-0.5" aria-hidden="true">
          {i === 0 && (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><polyline points="9 12 11 14 15 10" /></svg>
          )}
          {i === 1 && (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" /><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
          )}
          {i === 2 && (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><path d="M9 15l2 2 4-4" /></svg>
          )}
          {i === 3 && (
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="8.5" cy="7" r="4" /><path d="M20 8v6M23 11h-6" /></svg>
          )}
        </span>
        <div>
          <p class="text-xs font-semibold text-text-primary leading-tight">{item.title}</p>
          <p class="text-[11px] text-text-muted mt-0.5 leading-snug">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  const shareBtn = document.getElementById("share-product-btn");
  const shareLabel = document.getElementById("share-product-label");

  shareBtn?.addEventListener("click", async () => {
    const shareData = { title: document.title, url: window.location.href };
    try {
      if (navigator.share) {
        await navigator.share(shareData);
        return;
      }
    } catch {
      // user cancelled or share failed — fall through to clipboard
    }
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (shareLabel) {
        const original = shareLabel.textContent;
        shareLabel.textContent = "Link Copied!";
        setTimeout(() => {
          shareLabel.textContent = original;
        }, 2000);
      }
    } catch {
      // clipboard unavailable — silently no-op
    }
  });
</script>
