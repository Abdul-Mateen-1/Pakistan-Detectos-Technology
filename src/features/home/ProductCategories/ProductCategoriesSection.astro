---
/**
 * ProductCategoriesSection Component
 * Bento grid layout. Reads from src/data/categories.json.
 */
import Container from "../../../components/ui/Container.astro";

import categoriesData from "../../../data/categories.json";

const primaryCategory = categoriesData.primary;
const categories = categoriesData.secondary;
---

<section
  id="product-categories"
  class="relative bg-dark-surface py-[var(--spacing-section)]"
  aria-labelledby="categories-heading"
>
  <Container>
    <!-- Header -->
    <div class="flex items-center gap-4 justify-center mb-4" data-reveal="up">
      <span class="w-10 h-[2px] bg-primary eyebrow-line" aria-hidden="true"></span>
      <span class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary">
        Browse by Category
      </span>
      <span class="w-10 h-[2px] bg-primary eyebrow-line" aria-hidden="true"></span>
    </div>

    <h2
      id="categories-heading"
      class="font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.1] tracking-tight text-text-primary text-center mb-12 lg:mb-16"
      data-reveal="heading"
    >
      Find the Right Equipment
    </h2>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6">
      <!-- Primary Category: Gold Detectors (tall, spans 2 rows) -->
      <a
        href={`/categories/${primaryCategory.slug}`}
        class="group lg:row-span-2 relative flex flex-col rounded-xl border border-dark-border bg-dark-card overflow-hidden min-h-[280px] lg:min-h-0 transition-all duration-[280ms] ease-out hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_8px_26px_rgba(26,26,24,0.09),0_0_12px_rgba(148,116,42,0.07)]"
        data-reveal="up"
        aria-label={`${primaryCategory.name} — ${primaryCategory.count} products`}
      >
        {primaryCategory.image && (
          <div class="flex-1 min-h-[200px] lg:min-h-[280px] flex items-center justify-center px-8 pt-8 pb-2">
            <img
              src={primaryCategory.image}
              alt=""
              aria-hidden="true"
              loading="lazy"
              class="max-h-[200px] lg:max-h-[320px] w-auto max-w-full object-contain drop-shadow-[0_16px_24px_rgba(26,26,24,0.12)] transition-transform duration-[280ms] ease-out group-hover:scale-[1.04] pointer-events-none"
            />
          </div>
        )}

        <div class="relative p-6 lg:p-8 pt-4">
          <h3 class="font-display text-2xl lg:text-3xl text-text-primary leading-tight">
            {primaryCategory.name}
          </h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed max-w-sm">
            {primaryCategory.description}
          </p>
          <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-primary group-hover:underline">
            {primaryCategory.count} Products
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </span>
        </div>
      </a>

      <!-- Secondary Categories -->
      {categories.map((cat, index) => (
        <a
          href={`/categories/${cat.slug}`}
          class="group relative flex items-center gap-4 rounded-xl border border-dark-border bg-dark-card overflow-hidden min-h-[140px] p-5 lg:p-6 transition-all duration-[280ms] ease-out hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_8px_26px_rgba(26,26,24,0.09),0_0_12px_rgba(148,116,42,0.07)]"
          data-reveal="up"
          style={`transition-delay: ${(index + 1) * 80}ms;`}
          aria-label={`${cat.name} — ${cat.count} products`}
        >
          <div class="flex-1 min-w-0">
            <h3 class="text-base lg:text-lg font-semibold text-text-primary leading-tight">
              {cat.name}
            </h3>
            <span class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-primary group-hover:underline">
            {cat.count} Products
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
            </span>
          </div>

          {cat.image && (
            <div class="w-24 sm:w-28 lg:w-32 shrink-0 flex items-center justify-center">
              <img
                src={cat.image}
                alt=""
                aria-hidden="true"
                loading="lazy"
                class="max-h-[88px] lg:max-h-[96px] w-auto max-w-full object-contain drop-shadow-[0_8px_12px_rgba(26,26,24,0.10)] transition-transform duration-[280ms] ease-out group-hover:scale-[1.05] pointer-events-none"
              />
            </div>
          )}
        </a>
      ))}
    </div>
  </Container>
</section>

<script>
  const catObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          catObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );
  document.querySelectorAll("#product-categories [data-reveal]").forEach((el) => catObserver.observe(el));
</script>
