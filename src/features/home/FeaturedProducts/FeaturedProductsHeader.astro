---
/**
 * FeaturedProductsHeader Component
 * Dark-section header, consistent with the rest of the site.
 */
---

<div>
  <div class="flex items-center gap-4" data-reveal="up">
    <span class="w-10 h-[2px] bg-primary eyebrow-line" aria-hidden="true"></span>
    <span class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary">
      Featured Products
    </span>
  </div>

  <h2
    id="featured-heading"
    class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl leading-[1.1] tracking-tight text-text-primary"
    data-reveal="heading"
  >
    Our Most Popular Detectors
  </h2>
</div>
