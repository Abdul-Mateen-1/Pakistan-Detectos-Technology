---
/**
 * TrustIndicators Component
 * Compact trust badges shown in the hero section.
 */
const trustItems = [
  { icon: 'shield', label: 'Official Distributor' },
  { icon: 'award', label: 'Premium Brands' },
  { icon: 'headphones', label: 'Expert Support' },
];
---

<div class="flex flex-wrap items-center gap-x-5 gap-y-3">
  {trustItems.map((item) => (
    <div class="flex items-center gap-2.5 whitespace-nowrap">
      <div class="text-primary" aria-hidden="true">
        {item.icon === 'shield' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        )}
        {item.icon === 'award' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="7" />
            <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
          </svg>
        )}
        {item.icon === 'headphones' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
            <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" />
          </svg>
        )}
      </div>
      <span class="text-xs text-text-muted font-medium tracking-wide">
        {item.label}
      </span>
    </div>
  ))}
</div>
