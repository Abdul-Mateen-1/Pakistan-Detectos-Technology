---
/**
 * CatalogController Component
 * Single script controlling filtering, sorting, pagination, URL state,
 * chips, drawer sync, live counts, and empty state.
 *
 * Reads all products from a JSON island (embedded server-side) so pagination
 * knows every product's data regardless of what's visible in the DOM.
 * Filter/sort operates by hide/show on the pre-rendered cards, so no client
 * templating and no SEO/JS trade-off.
 *
 * Include AT MOST once per page.
 */
import products from "../../data/products.json";

interface Props {
  initialCategory?: string;
  initialBrand?: string;
}

const { initialCategory, initialBrand } = Astro.props;

// Compact JSON payload used by the script (only the fields it needs)
const productData = products.map((p) => ({
  id: p.id,
  category: p.category,
  brand: p.brand,
  price: p.price,
  name: p.name,
  featured: p.featured,
  dateAdded: (p as any).dateAdded ?? null,
}));

const initial = {
  category: initialCategory ?? null,
  brand: initialBrand ?? null,
};
---

<script
  id="catalog-data"
  type="application/json"
  set:html={JSON.stringify(productData)}
></script>
<script
  id="catalog-initial"
  type="application/json"
  set:html={JSON.stringify(initial)}
></script>

<script>
  // ------- Types -------
  type Product = {
    id: string;
    category: string;
    brand: string;
    price: number | null;
    name: string;
    featured: boolean;
    dateAdded: string | null;
  };
  type SortKey = "featured" | "price-asc" | "price-desc" | "newest" | "name-asc";

  // ------- Data / DOM refs -------
  const products: Product[] = JSON.parse(
    document.getElementById("catalog-data")?.textContent || "[]",
  );
  const initial: { category: string | null; brand: string | null } = JSON.parse(
    document.getElementById("catalog-initial")?.textContent || "{}",
  );

  const grid = document.getElementById("product-grid");
  const emptyState = document.getElementById("empty-state");
  const cardWrappers = Array.from(
    document.querySelectorAll<HTMLElement>(".product-card-wrapper"),
  );
  const chipsHost = document.getElementById("active-chips");
  const chipsClearAll = document.getElementById("chips-clear-all");
  const clearAllDesktop = document.querySelector<HTMLButtonElement>("[data-clear-all]");
  const clearAllMobile = document.querySelector<HTMLButtonElement>("[data-clear-all-mobile]");
  const drawerReset = document.getElementById("drawer-reset");
  const emptyClear = document.getElementById("empty-clear");
  const drawerBadge = document.getElementById("drawer-count-badge");
  const mobileCountEls = document.querySelectorAll<HTMLElement>("[data-mobile-count]");
  const activeCountEl = document.getElementById("active-count");
  const headerCountEl = document.getElementById("catalog-result-count");
  const headerNounEl = document.getElementById("catalog-result-noun");
  const emptyReasonEl = document.getElementById("empty-reason");
  const paginationRoot = document.getElementById("pagination");
  const paginationList = document.getElementById("pagination-list");
  const paginationRange = document.getElementById("pagination-range");

  const PAGE_SIZE = 24;

  // ------- State -------
  let selectedCategories = new Set<string>();
  let selectedBrands = new Set<string>();
  let priceMin: number | null = null;
  let priceMax: number | null = null;
  let includeQuote = true;
  let sortKey: SortKey = "featured";
  let currentPage = 1;

  // ------- URL sync -------
  // Brand slug → display-name lookup for URL round-tripping
  // (categoriesData.slug matches product.category, but brand URLs use slug
  //  while product.brand + inputs use display Name — reconcile here)
  const brandSlugToName: Record<string, string> = {};
  const brandNameToSlug: Record<string, string> = {};
  products.forEach((p) => {
    const slug = p.brand.toLowerCase();
    brandSlugToName[slug] = p.brand;
    brandNameToSlug[p.brand] = slug;
  });

  function readUrl() {
    const params = new URLSearchParams(window.location.search);
    const categoryQ = params.get("category");
    const brandQ = params.get("brand");
    selectedCategories = new Set(
      categoryQ ? categoryQ.split(",") : initial.category ? [initial.category] : [],
    );
    // URL brands are slugs — convert to display names to match input values
    const initialBrandSlug = initial.brand;
    const brandSlugs = brandQ ? brandQ.split(",") : initialBrandSlug ? [initialBrandSlug] : [];
    selectedBrands = new Set(
      brandSlugs.map((s) => brandSlugToName[s] ?? s),
    );
    priceMin = params.get("min") ? Number(params.get("min")) : null;
    priceMax = params.get("max") ? Number(params.get("max")) : null;
    includeQuote = params.get("noquote") !== "1";
    sortKey = (params.get("sort") as SortKey) || "featured";
    currentPage = params.get("page") ? Math.max(1, Number(params.get("page"))) : 1;
  }

  function writeUrl() {
    const params = new URLSearchParams();
    if (selectedCategories.size) params.set("category", [...selectedCategories].join(","));
    if (selectedBrands.size) {
      const brandSlugsForUrl = [...selectedBrands].map(
        (name) => brandNameToSlug[name] ?? name.toLowerCase(),
      );
      params.set("brand", brandSlugsForUrl.join(","));
    }
    if (priceMin != null) params.set("min", String(priceMin));
    if (priceMax != null) params.set("max", String(priceMax));
    if (!includeQuote) params.set("noquote", "1");
    if (sortKey !== "featured") params.set("sort", sortKey);
    if (currentPage > 1) params.set("page", String(currentPage));
    const qs = params.toString();
    const newUrl = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
    window.history.replaceState({}, "", newUrl);
  }

  // ------- Sync form inputs with state -------
  function syncInputsFromState() {
    // Desktop
    document.querySelectorAll<HTMLInputElement>(
      "[data-filter-input][name=category]",
    ).forEach((el) => {
      el.checked = selectedCategories.has(el.value);
    });
    document.querySelectorAll<HTMLInputElement>(
      "[data-filter-input][name=brand]",
    ).forEach((el) => {
      el.checked = selectedBrands.has(el.value);
    });
    const priceMinEl = document.getElementById("price-min") as HTMLInputElement | null;
    const priceMaxEl = document.getElementById("price-max") as HTMLInputElement | null;
    if (priceMinEl) priceMinEl.value = priceMin != null ? String(priceMin) : "";
    if (priceMaxEl) priceMaxEl.value = priceMax != null ? String(priceMax) : "";
    const includeEl = document.querySelector<HTMLInputElement>(
      "[data-filter-input][name=includeQuote]",
    );
    if (includeEl) includeEl.checked = includeQuote;

    // Mobile
    document.querySelectorAll<HTMLInputElement>(
      "[data-filter-input-mobile][name=category]",
    ).forEach((el) => {
      el.checked = selectedCategories.has(el.value);
    });
    document.querySelectorAll<HTMLInputElement>(
      "[data-filter-input-mobile][name=brand]",
    ).forEach((el) => {
      el.checked = selectedBrands.has(el.value);
    });
    const priceMinMob = document.getElementById("price-min-mobile") as HTMLInputElement | null;
    const priceMaxMob = document.getElementById("price-max-mobile") as HTMLInputElement | null;
    if (priceMinMob) priceMinMob.value = priceMin != null ? String(priceMin) : "";
    if (priceMaxMob) priceMaxMob.value = priceMax != null ? String(priceMax) : "";
    const includeMob = document.querySelector<HTMLInputElement>(
      "[data-filter-input-mobile][name=includeQuote]",
    );
    if (includeMob) includeMob.checked = includeQuote;

    // Sort selects
    document.querySelectorAll<HTMLSelectElement>("[data-sort-select]").forEach((sel) => {
      sel.value = sortKey;
    });
  }

  // ------- Filtering / sorting -------
  function matchesFilters(p: Product): boolean {
    if (selectedCategories.size && !selectedCategories.has(p.category)) return false;
    if (selectedBrands.size && !selectedBrands.has(p.brand)) return false;
    if (p.price == null) {
      if (!includeQuote) return false;
    } else {
      if (priceMin != null && p.price < priceMin) return false;
      if (priceMax != null && p.price > priceMax) return false;
    }
    return true;
  }

  function sortIds(ids: string[]): string[] {
    const map = new Map(products.map((p) => [p.id, p]));
    return [...ids].sort((a, b) => {
      const pa = map.get(a)!;
      const pb = map.get(b)!;
      switch (sortKey) {
        case "price-asc":
          return (pa.price ?? Infinity) - (pb.price ?? Infinity);
        case "price-desc":
          return (pb.price ?? -Infinity) - (pa.price ?? -Infinity);
        case "newest":
          return (pb.dateAdded ?? "").localeCompare(pa.dateAdded ?? "");
        case "name-asc":
          return pa.name.localeCompare(pb.name);
        case "featured":
        default:
          if (pa.featured !== pb.featured) return pa.featured ? -1 : 1;
          return pa.name.localeCompare(pb.name);
      }
    });
  }

  // ------- Render -------
  function render() {
    // 1) Determine which products pass filters
    const matchedIds = products.filter(matchesFilters).map((p) => p.id);
    const sortedIds = sortIds(matchedIds);
    const totalPages = Math.max(1, Math.ceil(sortedIds.length / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;

    const startIdx = (currentPage - 1) * PAGE_SIZE;
    const endIdx = startIdx + PAGE_SIZE;
    const visibleIds = new Set(sortedIds.slice(startIdx, endIdx));
    const pageOrder = sortedIds.slice(startIdx, endIdx);

    // 2) Kick off fade-out
    grid?.classList.add("is-refreshing");

    setTimeout(() => {
      // 3) Update visibility + DOM order to match sort
      cardWrappers.forEach((w) => {
        const id = w.dataset.productId!;
        const passesFilter = matchedIds.includes(id);
        w.classList.toggle("is-hidden-filter", !passesFilter);
        w.classList.toggle("is-hidden-page", passesFilter && !visibleIds.has(id));
      });
      // Reorder in DOM per sort
      if (grid) {
        pageOrder.forEach((id) => {
          const el = grid.querySelector<HTMLElement>(
            `.product-card-wrapper[data-product-id="${id}"]`,
          );
          if (el) grid.appendChild(el);
        });
      }

      // 4) Show/hide empty state
      const isEmpty = sortedIds.length === 0;
      grid?.classList.toggle("hidden", isEmpty);
      grid?.classList.toggle("grid", !isEmpty);
      emptyState?.classList.toggle("hidden", !isEmpty);
      emptyState?.classList.toggle("flex", isEmpty);

      if (isEmpty && emptyReasonEl) {
        emptyReasonEl.textContent = buildEmptyReason();
      }

      // 5) Fade back in
      grid?.classList.remove("is-refreshing");
      grid?.classList.add("is-refreshed");
      setTimeout(() => grid?.classList.remove("is-refreshed"), 300);

      // 6) Update counts, chips, pagination, URL
      updateCounts(sortedIds.length);
      renderChips();
      renderPagination(sortedIds.length, totalPages);
      updateLiveCounts(matchedIds);
      writeUrl();
    }, 150);
  }

  function updateCounts(total: number) {
    if (headerCountEl) headerCountEl.textContent = String(total);
    if (headerNounEl) headerNounEl.textContent = total === 1 ? "product" : "products";
    if (activeCountEl) activeCountEl.textContent = String(total);
    mobileCountEls.forEach((el) => (el.textContent = String(total)));

    const activeFilterCount =
      selectedCategories.size +
      selectedBrands.size +
      (priceMin != null || priceMax != null ? 1 : 0) +
      (!includeQuote ? 1 : 0);
    if (drawerBadge) {
      drawerBadge.classList.toggle("hidden", activeFilterCount === 0);
      drawerBadge.classList.toggle("flex", activeFilterCount > 0);
      drawerBadge.textContent = String(activeFilterCount);
    }
    if (clearAllDesktop) {
      clearAllDesktop.classList.toggle("hidden", activeFilterCount === 0);
    }
  }

  function updateLiveCounts(matchedIds: string[]) {
    // Count how many pass all *other* filters for each category / brand option
    document.querySelectorAll<HTMLElement>("[data-count-category]").forEach((el) => {
      const slug = el.dataset.countCategory!;
      const count = products.filter((p) => {
        if (p.category !== slug) return false;
        if (selectedBrands.size && !selectedBrands.has(p.brand)) return false;
        if (p.price == null) return includeQuote;
        if (priceMin != null && p.price < priceMin) return false;
        if (priceMax != null && p.price > priceMax) return false;
        return true;
      }).length;
      el.textContent = String(count);
    });
    document.querySelectorAll<HTMLElement>("[data-count-brand]").forEach((el) => {
      const slug = el.dataset.countBrand!;
      const brandName = brandSlugToName[slug];
      if (!brandName) {
        el.textContent = "0";
        return;
      }
      const count = products.filter((p) => {
        if (p.brand !== brandName) return false;
        if (selectedCategories.size && !selectedCategories.has(p.category)) return false;
        if (p.price == null) return includeQuote;
        if (priceMin != null && p.price < priceMin) return false;
        if (priceMax != null && p.price > priceMax) return false;
        return true;
      }).length;
      el.textContent = String(count);
    });
  }

  function buildEmptyReason(): string {
    const parts: string[] = [];
    if (selectedCategories.size) {
      parts.push([...selectedCategories].map(slugToLabel).join(" + "));
    }
    if (selectedBrands.size) parts.push([...selectedBrands].join(" + "));
    if (priceMin != null || priceMax != null) {
      const min = priceMin != null ? `PKR ${priceMin.toLocaleString("en-PK")}` : "any";
      const max = priceMax != null ? `PKR ${priceMax.toLocaleString("en-PK")}` : "any";
      parts.push(`${min}–${max}`);
    }
    if (!parts.length) return "No products found. Try adjusting your filters.";
    return `No products match ${parts.join(", ")}. Try broadening your filters or clearing them to see all products.`;
  }

  function slugToLabel(slug: string): string {
    return slug.split("-").map((w) => w[0].toUpperCase() + w.slice(1)).join(" ");
  }

  // ------- Chips -------
  function renderChips() {
    if (!chipsHost) return;
    chipsHost.innerHTML = "";
    const chips: { key: string; label: string; onRemove: () => void }[] = [];

    selectedCategories.forEach((slug) => {
      chips.push({
        key: `cat-${slug}`,
        label: slugToLabel(slug),
        onRemove: () => {
          selectedCategories.delete(slug);
          currentPage = 1;
          syncInputsFromState();
          render();
        },
      });
    });
    selectedBrands.forEach((brand) => {
      chips.push({
        key: `brand-${brand}`,
        label: brand,
        onRemove: () => {
          selectedBrands.delete(brand);
          currentPage = 1;
          syncInputsFromState();
          render();
        },
      });
    });
    if (priceMin != null || priceMax != null) {
      const min = priceMin != null ? `PKR ${(priceMin / 1000).toFixed(0)}K` : "any";
      const max = priceMax != null ? `PKR ${(priceMax / 1000).toFixed(0)}K` : "any";
      chips.push({
        key: "price",
        label: `${min}–${max}`,
        onRemove: () => {
          priceMin = null;
          priceMax = null;
          currentPage = 1;
          syncInputsFromState();
          render();
        },
      });
    }
    if (!includeQuote) {
      chips.push({
        key: "noquote",
        label: "Excludes quote-only",
        onRemove: () => {
          includeQuote = true;
          currentPage = 1;
          syncInputsFromState();
          render();
        },
      });
    }

    chips.forEach((c) => {
      const el = document.createElement("span");
      el.className = "filter-chip";
      el.setAttribute("role", "listitem");
      el.innerHTML = `
        <span>${c.label}</span>
        <button type="button" aria-label="Remove filter: ${c.label}">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>`;
      el.querySelector("button")?.addEventListener("click", c.onRemove);
      chipsHost.appendChild(el);
    });

    chipsClearAll?.classList.toggle("hidden", chips.length === 0);
  }

  // ------- Pagination -------
  function renderPagination(total: number, totalPages: number) {
    if (!paginationRoot || !paginationList || !paginationRange) return;

    // Always show the pagination container for the range text
    paginationRoot.classList.remove("hidden");
    paginationRoot.classList.add("flex");

    if (totalPages <= 1) {
      // Single page: hide page buttons, still show "Showing 1–X of X products"
      paginationList.innerHTML = "";
      paginationList.classList.add("hidden");
      const startIdx = 1;
      const endIdx = total;
      paginationRange.textContent = total > 0
        ? `Showing ${startIdx}–${endIdx} of ${total} products`
        : "";
      return;
    }
    paginationList.classList.remove("hidden");

    const startIdx = (currentPage - 1) * PAGE_SIZE + 1;
    const endIdx = Math.min(currentPage * PAGE_SIZE, total);
    paginationRange.textContent = `Showing ${startIdx}–${endIdx} of ${total} products`;

    paginationList.innerHTML = "";

    const isMobile = window.matchMedia("(max-width: 640px)").matches;

    const addBtn = (label: string, page: number, opts: { active?: boolean; disabled?: boolean; ariaLabel?: string } = {}) => {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.className = "page-btn";
      if (opts.active) a.classList.add("is-active");
      if (opts.disabled) a.classList.add("is-disabled");
      a.textContent = label;
      const params = new URLSearchParams(window.location.search);
      if (page > 1) params.set("page", String(page));
      else params.delete("page");
      const qs = params.toString();
      a.href = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
      if (opts.ariaLabel) a.setAttribute("aria-label", opts.ariaLabel);
      if (opts.active) a.setAttribute("aria-current", "page");
      a.addEventListener("click", (e) => {
        e.preventDefault();
        if (opts.disabled || opts.active) return;
        currentPage = page;
        render();
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
      li.appendChild(a);
      paginationList.appendChild(li);
    };

    const addEllipsis = () => {
      const li = document.createElement("li");
      const span = document.createElement("span");
      span.className = "page-ellipsis";
      span.textContent = "…";
      span.setAttribute("aria-hidden", "true");
      li.appendChild(span);
      paginationList.appendChild(li);
    };

    // Prev
    addBtn("‹", currentPage - 1, {
      disabled: currentPage === 1,
      ariaLabel: "Previous page",
    });

    // Page numbers
    if (isMobile) {
      addBtn("1", 1, { active: currentPage === 1 });
      if (currentPage > 2) addEllipsis();
      if (currentPage !== 1 && currentPage !== totalPages) {
        addBtn(String(currentPage), currentPage, { active: true });
      }
      if (currentPage < totalPages - 1) addEllipsis();
      if (totalPages > 1) addBtn(String(totalPages), totalPages, { active: currentPage === totalPages });
    } else {
      const pages: (number | "…")[] = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) pages.push(i);
      } else {
        pages.push(1);
        if (currentPage > 3) pages.push("…");
        const start = Math.max(2, currentPage - 1);
        const end = Math.min(totalPages - 1, currentPage + 1);
        for (let i = start; i <= end; i++) pages.push(i);
        if (currentPage < totalPages - 2) pages.push("…");
        pages.push(totalPages);
      }
      pages.forEach((p) => {
        if (p === "…") addEllipsis();
        else addBtn(String(p), p, { active: p === currentPage });
      });
    }

    // Next
    addBtn("›", currentPage + 1, {
      disabled: currentPage === totalPages,
      ariaLabel: "Next page",
    });
  }

  // ------- Event wiring -------
  function readFromInputs(scope: "desktop" | "mobile") {
    const selCategory = scope === "desktop" ? "[data-filter-input]" : "[data-filter-input-mobile]";
    document.querySelectorAll<HTMLInputElement>(`${selCategory}[name=category]`).forEach((el) => {
      if (el.checked) selectedCategories.add(el.value);
      else selectedCategories.delete(el.value);
    });
    document.querySelectorAll<HTMLInputElement>(`${selCategory}[name=brand]`).forEach((el) => {
      if (el.checked) selectedBrands.add(el.value);
      else selectedBrands.delete(el.value);
    });
    const minEl = document.getElementById(scope === "desktop" ? "price-min" : "price-min-mobile") as HTMLInputElement | null;
    const maxEl = document.getElementById(scope === "desktop" ? "price-max" : "price-max-mobile") as HTMLInputElement | null;
    priceMin = minEl?.value ? Number(minEl.value) : null;
    priceMax = maxEl?.value ? Number(maxEl.value) : null;
    const includeEl = document.querySelector<HTMLInputElement>(`${selCategory}[name=includeQuote]`);
    includeQuote = includeEl ? includeEl.checked : true;
  }

  document.querySelectorAll<HTMLInputElement>("[data-filter-input]").forEach((el) => {
    el.addEventListener("change", () => {
      readFromInputs("desktop");
      currentPage = 1;
      syncInputsFromState();
      render();
    });
  });
  document.querySelectorAll<HTMLInputElement>("[data-filter-input-mobile]").forEach((el) => {
    el.addEventListener("change", () => {
      readFromInputs("mobile");
      currentPage = 1;
      syncInputsFromState();
      render();
    });
  });
  document.querySelectorAll<HTMLSelectElement>("[data-sort-select]").forEach((sel) => {
    sel.addEventListener("change", () => {
      sortKey = sel.value as SortKey;
      currentPage = 1;
      syncInputsFromState();
      render();
    });
  });

  function clearAll() {
    selectedCategories.clear();
    selectedBrands.clear();
    priceMin = null;
    priceMax = null;
    includeQuote = true;
    currentPage = 1;
    syncInputsFromState();
    render();
  }
  clearAllDesktop?.addEventListener("click", clearAll);
  clearAllMobile?.addEventListener("click", clearAll);
  drawerReset?.addEventListener("click", clearAll);
  chipsClearAll?.addEventListener("click", clearAll);
  emptyClear?.addEventListener("click", clearAll);

  // ------- Initial paint -------
  readUrl();
  syncInputsFromState();
  render();
</script>
