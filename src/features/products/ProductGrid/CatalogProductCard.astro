---
/**
 * CatalogProductCard Component
 * Dark-theme product card for the catalog/products page.
 * Matches the dark luxury aesthetic — dark card bg, gold accents,
 * brand label top-left, badge top-right, spec tags, price row.
 *
 * Image area: overflow-hidden hides alt text fallback.
 * Descriptions clamped to 2 lines. Spec row takes fixed min-height.
 * "Request Quote" matches PKR price styling for consistency.
 */
interface Props {
  name: string;
  brand: string;
  price: number | null;
  description: string;
  image: string;
  slug: string;
  badge: string | null;
  specs: string[];
  index: number;
}

const { name, brand, price, description, image, slug, badge, specs, index } = Astro.props;
const formattedPrice = price ? price.toLocaleString("en-PK") : null;
---

<a
  href={`/products/${slug}`}
  aria-label={`${name} — view details`}
  class="catalog-card group flex flex-col h-full bg-dark-card rounded-xl border border-dark-border overflow-hidden transition-all duration-[280ms] ease-out hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_8px_30px_rgba(0,0,0,0.4),0_0_16px_rgba(197,160,68,0.1)]"
>
  <!-- Image Container -->
  <div class="relative p-4 pb-2">
    <!-- Brand Badge (top-left) -->
    <span class="absolute top-3 left-3 z-10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-text-secondary bg-dark-surface rounded border border-dark-border">
      {brand}
    </span>

    <!-- Bestseller / New Badge (top-right) -->
    {badge && (
      <span class="absolute top-3 right-3 z-10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-dark bg-primary rounded">
        {badge}
      </span>
    )}

    <!-- Product Image — overflow-hidden hides broken-image alt text -->
    <div class="catalog-card-img aspect-[4/3] flex items-center justify-center rounded-lg bg-white mt-2 overflow-hidden">
      <img
        src={image}
        alt={`${name} by ${brand}`}
        width="400"
        height="300"
        class="w-full h-full object-contain transition-transform duration-[280ms] ease-out group-hover:scale-105 p-4"
        loading="lazy"
      />
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 px-4 pb-4 pt-2">
    <h3 class="text-base font-semibold text-text-primary leading-snug">{name}</h3>
    <p class="mt-1.5 text-sm text-text-secondary leading-relaxed line-clamp-2">{description}</p>

    <!-- Spec Tags (fixed min-height for row consistency) -->
    <div class="mt-3 min-h-[28px] flex flex-wrap gap-1.5 items-start">
      {specs.map((spec) => (
        <span class="px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-text-muted bg-dark rounded">
          {spec}
        </span>
      ))}
    </div>

    <!-- Price Row -->
    <div class="mt-auto pt-4 flex items-end justify-between gap-4">
      <div class="flex flex-col">
        <span class="text-[10px] font-medium uppercase tracking-wider text-text-muted">Price</span>
        {formattedPrice ? (
          <div class="flex items-baseline gap-1.5">
            <span class="text-[11px] font-bold text-text-muted">PKR</span>
            <span class="text-lg font-bold text-primary">{formattedPrice}</span>
          </div>
        ) : (
          <span class="text-lg font-bold text-text-primary">Request Quote</span>
        )}
      </div>

      <span
        class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:text-primary-hover transition-colors duration-200 shrink-0"
      >
        View Details →
      </span>
    </div>
  </div>
</a>

<style>
  /* Hide broken image alt text — show only the white tile */
  .catalog-card-img img {
    color: transparent;
  }
  .catalog-card-img img::before {
    content: '';
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
