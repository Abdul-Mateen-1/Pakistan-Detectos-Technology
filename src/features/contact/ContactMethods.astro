---
/**
 * ContactMethods Component (Contact Page)
 * 4-card row (WhatsApp/Call/Email/Showroom) — real values and working
 * links derived from site.json (tel:, mailto:, wa.me, Maps search).
 */
import site from "../../data/site.json";

const whatsappDigits = site.contact.whatsapp.replace("https://wa.me/", "");
const whatsappDisplay = `+${whatsappDigits.slice(0, 2)}-${whatsappDigits.slice(2)}`;
const telHref = `tel:${site.contact.phone.replace(/[^\d+]/g, "")}`;
const mapsHref = site.contact.mapsUrl;

const methods = [
  {
    icon: "whatsapp",
    title: "WhatsApp",
    value: whatsappDisplay,
    note: "Fastest response — typically under 1 hour",
    href: site.contact.whatsapp,
    external: true,
    accent: "whatsapp",
  },
  {
    icon: "phone",
    title: "Call Us",
    value: site.contact.phone,
    note: site.contact.hours,
    href: telHref,
    external: false,
    accent: "primary",
  },
  {
    icon: "email",
    title: "Email",
    value: site.contact.email,
    note: "Response within 24 hours",
    href: `mailto:${site.contact.email}`,
    external: false,
    accent: "primary",
  },
  {
    icon: "pin",
    title: "Visit Showroom",
    value: site.contact.address,
    note: "By appointment — call ahead",
    href: mapsHref,
    external: true,
    accent: "primary",
  },
];
---

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
  {methods.map((method, i) => (
    <a
      href={method.href}
      target={method.external ? "_blank" : undefined}
      rel={method.external ? "noopener noreferrer" : undefined}
      class="flex flex-col items-center text-center p-6 rounded-xl bg-dark-card border border-dark-border transition-all duration-200 hover:-translate-y-1 hover:border-primary/40"
      data-reveal="up"
      style={`transition-delay: ${i * 80}ms;`}
    >
      <div
        class:list={[
          "flex items-center justify-center w-11 h-11 rounded-lg mb-4",
          method.accent === "whatsapp" ? "bg-whatsapp/15 text-whatsapp" : "bg-primary/15 text-primary",
        ]}
        aria-hidden="true"
      >
        {method.icon === "whatsapp" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        )}
        {method.icon === "phone" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
        )}
        {method.icon === "email" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
        )}
        {method.icon === "pin" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
        )}
      </div>
      <h3 class="text-base font-semibold text-text-primary">{method.title}</h3>
      <p class:list={["mt-1.5 text-sm font-medium", method.accent === "whatsapp" ? "text-whatsapp" : "text-primary"]}>
        {method.value}
      </p>
      <p class="mt-1.5 text-xs text-text-muted leading-snug">{method.note}</p>
    </a>
  ))}
</div>
