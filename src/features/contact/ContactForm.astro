---
/**
 * ContactForm Component (Contact Page)
 * IMPORTANT: no backend/email service exists anywhere in this project.
 * Since WhatsApp is already the site's established primary contact
 * channel (fastest response, featured first in ContactMethods), this
 * form validates client-side then opens a pre-filled WhatsApp message
 * to the business number on submit — a real, working, backend-free
 * substitute for a traditional form POST. No data is emailed or stored.
 */
import Button from "../../components/ui/Button.astro";
import site from "../../data/site.json";

const whatsappDigits = site.contact.whatsapp.replace("https://wa.me/", "");

const subjectOptions = [
  "Product Inquiry",
  "Request Quote",
  "Technical Support",
  "Bulk Order",
  "Training",
  "Other",
];
---

<div class="rounded-2xl border border-dark-border bg-dark-card p-6 lg:p-8" data-reveal="up">
  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-primary">Send a Message</span>
  <h2 class="mt-2 font-display text-2xl sm:text-3xl text-text-primary leading-tight">Request a Quote or Ask a Question</h2>
  <p class="mt-2 text-sm text-text-secondary">Fill out the form and our team will get back to you within one business day.</p>

  <form id="contact-form" data-whatsapp-number={whatsappDigits} class="mt-6 flex flex-col gap-5" novalidate>
    <div class="grid sm:grid-cols-2 gap-5">
      <div>
        <label for="first-name" class="block text-xs font-medium text-text-secondary mb-1.5">First Name *</label>
        <input type="text" id="first-name" name="firstName" required placeholder="Enter first name" class="form-input" />
      </div>
      <div>
        <label for="last-name" class="block text-xs font-medium text-text-secondary mb-1.5">Last Name *</label>
        <input type="text" id="last-name" name="lastName" required placeholder="Enter last name" class="form-input" />
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      <div>
        <label for="email" class="block text-xs font-medium text-text-secondary mb-1.5">Email *</label>
        <input type="email" id="email" name="email" required placeholder="your@email.com" class="form-input" />
      </div>
      <div>
        <label for="phone" class="block text-xs font-medium text-text-secondary mb-1.5">Phone / WhatsApp</label>
        <input type="tel" id="phone" name="phone" placeholder="+92-3XX-XXXXXXX" class="form-input" />
      </div>
    </div>

    <div>
      <label for="company" class="block text-xs font-medium text-text-secondary mb-1.5">Company / Organization</label>
      <input type="text" id="company" name="company" placeholder="Optional" class="form-input" />
    </div>

    <div>
      <label for="subject" class="block text-xs font-medium text-text-secondary mb-1.5">Subject *</label>
      <div class="relative">
        <select id="subject" name="subject" required class="form-input appearance-none pr-10 cursor-pointer">
          {subjectOptions.map((opt) => (
            <option value={opt} selected={opt === "Request Quote"}>{opt}</option>
          ))}
        </select>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-text-muted pointer-events-none" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        {subjectOptions.map((opt) => (
          <button
            type="button"
            data-subject-pill={opt}
            class:list={["subject-pill px-3.5 py-1.5 text-xs font-medium rounded-full border transition-colors duration-200 cursor-pointer", opt === "Request Quote" ? "is-active" : "border-dark-border text-text-secondary hover:border-primary/40"]}
          >
            {opt}
          </button>
        ))}
      </div>
    </div>

    <div>
      <label for="message" class="block text-xs font-medium text-text-secondary mb-1.5">Message *</label>
      <textarea
        id="message"
        name="message"
        required
        rows="4"
        placeholder="Tell us what you're looking for — include product names, quantities, or any specific requirements…"
        class="form-input resize-none"
      ></textarea>
    </div>

    <Button type="submit" variant="primary" size="lg" class="w-full justify-center">
      Send Message
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </Button>

    <p class="text-xs text-text-muted text-center -mt-1">
      Sending opens a pre-filled WhatsApp message to our team — you'll confirm and send it from there.
    </p>
  </form>
</div>

<style>
  .form-input {
    width: 100%;
    background-color: var(--color-dark-surface);
    border: 1px solid var(--color-dark-border);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--color-text-primary);
    transition: border-color 200ms ease-out;
  }
  .form-input::placeholder {
    color: var(--color-text-muted);
  }
  .form-input:focus-visible {
    outline: none;
    border-color: var(--color-primary);
  }
  .subject-pill.is-active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-dark);
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const subjectSelect = document.getElementById("subject") as HTMLSelectElement | null;
  const pills = document.querySelectorAll<HTMLButtonElement>(".subject-pill");

  function setActivePill(value: string) {
    pills.forEach((pill) => {
      pill.classList.toggle("is-active", pill.dataset.subjectPill === value);
      pill.classList.toggle("border-dark-border", pill.dataset.subjectPill !== value);
      pill.classList.toggle("text-text-secondary", pill.dataset.subjectPill !== value);
    });
  }

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const value = pill.dataset.subjectPill || "";
      if (subjectSelect) subjectSelect.value = value;
      setActivePill(value);
    });
  });

  subjectSelect?.addEventListener("change", () => {
    setActivePill(subjectSelect.value);
  });

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const lines = [
      "New inquiry from website:",
      `Name: ${data.get("firstName")} ${data.get("lastName")}`,
      `Email: ${data.get("email")}`,
      data.get("phone") ? `Phone: ${data.get("phone")}` : null,
      data.get("company") ? `Company: ${data.get("company")}` : null,
      `Subject: ${data.get("subject")}`,
      `Message: ${data.get("message")}`,
    ].filter(Boolean);

    const text = encodeURIComponent(lines.join("\n"));
    const number = form.dataset.whatsappNumber || "";
    window.open(`https://wa.me/${number}?text=${text}`, "_blank", "noopener,noreferrer");
  });
</script>
