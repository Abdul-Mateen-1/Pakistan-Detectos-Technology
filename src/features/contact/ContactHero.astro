---
/**
 * ContactHero Component (Contact Page)
 * Centered eyebrow/H1/description.
 */
---

<div class="text-center max-w-2xl mx-auto">
  <div class="flex items-center justify-center gap-4" data-reveal="up">
    <span class="w-10 h-[2px] bg-primary" aria-hidden="true"></span>
    <span class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary">Get in Touch</span>
    <span class="w-10 h-[2px] bg-primary" aria-hidden="true"></span>
  </div>
  <h1 class="mt-4 font-display text-[32px] sm:text-4xl lg:text-[44px] leading-[1.1] tracking-tight text-text-primary" data-reveal="up">
    We'd Love to Hear from You
  </h1>
  <p class="mt-4 text-sm sm:text-base text-text-secondary leading-relaxed" data-reveal="up">
    Whether you need product advice, a custom quote, or technical support — our team is ready to help. Choose the channel that works best for you.
  </p>
</div>
