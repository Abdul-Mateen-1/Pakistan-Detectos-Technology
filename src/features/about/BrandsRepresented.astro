---
/**
 * BrandsRepresented Component (About Page)
 * Centered header + 8 brand pills, each linking to its real /brands/[slug] page.
 */
import Container from "../../components/ui/Container.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import brands from "../../data/brands.json";
---

<section class="py-16 lg:py-20 border-t border-dark-border" aria-labelledby="brands-represented-heading">
  <Container>
    <SectionHeading
      eyebrow="Authorized Distributor"
      heading="Brands We Represent"
      align="center"
      theme="dark"
      headingId="brands-represented-heading"
    />

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {brands.map((brand, i) => (
        <a
          href={`/brands/${brand.slug}`}
          class="px-6 py-3 rounded-lg bg-dark-card border border-dark-border text-sm font-medium text-text-secondary hover:text-primary hover:border-primary/40 transition-colors duration-200"
          data-reveal="up"
          style={`transition-delay: ${i * 60}ms;`}
        >
          {brand.name}
        </a>
      ))}
    </div>
  </Container>
</section>
