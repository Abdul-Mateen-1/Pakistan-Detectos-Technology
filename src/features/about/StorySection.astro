---
/**
 * StorySection Component (About Page)
 * Page H1 + 2 paragraphs (left) + image placeholder with overlapping
 * "years in business" floating card (right). Pulls the years figure from
 * stats.json — same source as CompanyStatsSection further down the page —
 * so the two never contradict each other.
 */
import stats from "../../data/stats.json";
import aboutImage from "../../assets/aboutus.jpg";

const yearsStat = stats.find((s) => s.label === "Years in Business");
---

<div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
  <div data-reveal="up">
    <div class="flex items-center gap-4">
      <span class="w-10 h-[2px] bg-primary eyebrow-line" aria-hidden="true"></span>
      <span
        class="text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase text-primary"
        >Our Story</span
      >
    </div>
    <h1
      class="mt-4 font-display text-[32px] sm:text-4xl lg:text-[44px] leading-[1.1] tracking-tight text-text-primary"
      data-reveal="heading"
    >
      Pakistan's Most Trusted Name in Detection Equipment
    </h1>
    <p class="mt-5 text-sm sm:text-[15px] text-text-secondary leading-relaxed">
      Since 2015, Pakistan Detectors Technology has been the country's premier
      source for professional detection equipment. We are the authorized
      distributor for the world's most respected manufacturers — bringing
      genuine, warranty-backed products to prospectors, mining companies, and
      government organizations across Pakistan and Afghanistan.
    </p>
    <p class="mt-4 text-sm sm:text-[15px] text-text-secondary leading-relaxed">
      What started as a passion for detection technology has grown into a
      full-service operation with expert consultants, nationwide delivery,
      product training, and after-sales support that our clients rely on.
    </p>
  </div>

  <div class="relative pb-8" data-reveal="up">
    <div
      class="aspect-[4/3] rounded-xl bg-dark-card border border-dark-border overflow-hidden"
    >
      <img
        src={aboutImage.src}
        alt="Pakistan Detectors Technology — field prospecting with professional detection equipment"
        class="w-full h-full object-cover"
        width={aboutImage.width}
        height={aboutImage.height}
        loading="eager"
      />
    </div>

    <div
      class="absolute bottom-0 left-4 sm:left-6 flex items-center gap-3 bg-dark-card border border-dark-border rounded-lg px-5 py-4 shadow-card"
    >
      <span
        class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary/15 text-primary shrink-0"
        aria-hidden="true"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
        >
      </span>
      <div>
        <p
          class="text-base font-bold text-text-primary leading-tight whitespace-nowrap"
        >
          {yearsStat?.value}{yearsStat?.suffix} Years
        </p>
        <p class="text-xs text-text-muted mt-0.5">
          Serving Pakistan &amp; Afghanistan
        </p>
      </div>
    </div>
  </div>
</div>
