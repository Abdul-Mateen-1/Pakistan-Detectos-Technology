---
/**
 * WhatSetsUsApartSection Component (About Page)
 * Centered header + 8-card dark icon grid (4x2 on desktop).
 * Left-aligned card content — distinct from the homepage's centered
 * WhyChooseUsSection (light theme), though 4 icons are shared for
 * consistency where the meaning overlaps (shield/truck/check/headset).
 */
import Container from "../../components/ui/Container.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";

const items = [
  {
    icon: "shield",
    title: "Official Distributor",
    description: "Authorized dealer for all 8 brands. Every product purchased from us is 100% genuine with full manufacturer backing.",
  },
  {
    icon: "truck",
    title: "Nationwide Delivery",
    description: "Insured shipping to all major cities and remote mining locations across Pakistan. Deliveries to Afghanistan arranged on request.",
  },
  {
    icon: "message",
    title: "Expert Consultation",
    description: "Our specialists understand Pakistan's terrain, soil conditions, and equipment requirements. We recommend equipment that works here — not generic advice.",
  },
  {
    icon: "cap",
    title: "Training & Installation",
    description: "Free product training for every purchase. We don't just sell equipment — we ensure your team can operate it effectively in the field.",
  },
  {
    icon: "check",
    title: "Warranty Coverage",
    description: "Full manufacturer warranty honored locally. Our service center handles repairs, calibration, and maintenance in Pakistan.",
  },
  {
    icon: "headset",
    title: "After-Sales Support",
    description: "Ongoing technical support via WhatsApp, phone, and in-person consultations. We're here for you long after the sale.",
  },
  {
    icon: "package",
    title: "Genuine Parts & Accessories",
    description: "Original replacement coils, batteries, headphones and accessories. No third-party substitutes — only manufacturer-approved components.",
  },
  {
    icon: "globe",
    title: "Regional Expertise",
    description: "Deep understanding of gold-bearing regions in KPK, Balochistan, and Gilgit-Baltistan. We advise on terrain-specific equipment selection.",
  },
];
---

<section class="py-16 lg:py-20 border-t border-dark-border" aria-labelledby="apart-heading">
  <Container>
    <SectionHeading eyebrow="Why Choose Us" heading="What Sets Us Apart" align="center" theme="dark" headingId="apart-heading" />

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {items.map((item, i) => (
        <div
          class="p-6 rounded-xl bg-dark-card border border-dark-border"
          data-reveal="up"
          style={`transition-delay: ${(i % 4) * 80}ms;`}
        >
          <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-primary/15 text-primary mb-4" aria-hidden="true">
            {item.icon === "shield" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
            )}
            {item.icon === "truck" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" /><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
            )}
            {item.icon === "message" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /></svg>
            )}
            {item.icon === "cap" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10L12 5 2 10l10 5 10-5z" /><path d="M6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5" /></svg>
            )}
            {item.icon === "check" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="m9 12 2 2 4-4" /></svg>
            )}
            {item.icon === "headset" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6" /><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" /></svg>
            )}
            {item.icon === "package" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /><polyline points="3.27 6.96 12 12.01 20.73 6.96" /><line x1="12" y1="22.08" x2="12" y2="12" /></svg>
            )}
            {item.icon === "globe" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg>
            )}
          </div>
          <h3 class="text-base font-semibold text-text-primary">{item.title}</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
