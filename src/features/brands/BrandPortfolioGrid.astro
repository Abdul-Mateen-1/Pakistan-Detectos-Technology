---
/**
 * BrandPortfolioGrid Component (Brands Index)
 * "Complete Brand Portfolio" — compact whole-card-clickable cards for
 * brands without a full showcase block (Fisher, Teknetics, XP, GoldXtra).
 */
import Container from "../../components/ui/Container.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";

interface Stat {
  value: string;
  label: string;
}
interface Brand {
  name: string;
  slug: string;
  initials: string;
  location: string;
  foundedYear: number;
  description: string;
  pageStats: Stat[];
}

interface Props {
  brands: Brand[];
}

const { brands } = Astro.props;
---

<section class="py-16 lg:py-20 border-t border-dark-border" aria-labelledby="portfolio-heading">
  <Container>
    <SectionHeading
      eyebrow="More Brands We Carry"
      heading="Complete Brand Portfolio"
      align="center"
      theme="dark"
      headingId="portfolio-heading"
    />

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {brands.map((brand, i) => (
        <a
          href={`/brands/${brand.slug}`}
          aria-label={`${brand.name} — view products`}
          class="group flex flex-col p-6 rounded-xl bg-dark-card border border-dark-border transition-all duration-200 hover:-translate-y-1 hover:border-primary/40"
          data-reveal="up"
          style={`transition-delay: ${i * 80}ms;`}
        >
          <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-dark-surface border border-dark-border text-primary font-display text-sm" aria-hidden="true">
            {brand.initials}
          </div>
          <h3 class="mt-4 text-base font-semibold text-text-primary">{brand.name}</h3>
          <p class="mt-1 text-xs text-text-muted">{brand.location} · Est. {brand.foundedYear}</p>
          <p class="mt-3 text-xs text-text-secondary leading-relaxed line-clamp-3 flex-1">{brand.description}</p>

          <div class="flex items-center gap-6 mt-4 pt-4 border-t border-dark-border/60">
            {brand.pageStats.map((stat) => (
              <div class="flex flex-col">
                <span class="text-base font-bold text-primary">{stat.value}</span>
                <span class="text-[9px] font-medium uppercase tracking-wider text-text-muted mt-0.5">{stat.label}</span>
              </div>
            ))}
          </div>

          <span class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-primary group-hover:text-primary-hover transition-colors duration-200">
            View Products →
          </span>
        </a>
      ))}
    </div>
  </Container>
</section>
