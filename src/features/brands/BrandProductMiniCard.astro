---
/**
 * BrandProductMiniCard Component (Brands Index)
 * Compact whole-card-clickable product card used inside FeaturedBrandBlock's
 * product grid. Deliberately lighter than CatalogProductCard — no brand
 * badge (redundant within a brand-specific block) and no spec tags.
 */
interface Props {
  name: string;
  description: string;
  price: number | null;
  image: string;
  slug: string;
}

const { name, description, price, image, slug } = Astro.props;
const formattedPrice = price ? price.toLocaleString("en-PK") : null;
---

<a
  href={`/products/${slug}`}
  aria-label={`${name} — view details`}
  class="group flex flex-col bg-dark-surface rounded-lg border border-dark-border overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40"
>
  <div class="mini-card-img aspect-[4/3] flex items-center justify-center bg-white overflow-hidden">
    <img
      src={image}
      alt={name}
      width="300"
      height="225"
      class="w-full h-full object-contain p-6 transition-transform duration-200 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="flex flex-col gap-1 p-4">
    <h3 class="text-sm font-semibold text-text-primary leading-snug">{name}</h3>
    <p class="text-xs text-text-muted leading-relaxed line-clamp-1">{description}</p>
    <p class="mt-1 text-sm font-bold text-primary">
      {formattedPrice ? `PKR ${formattedPrice}` : "Request Quote"}
    </p>
  </div>
</a>

<style>
  .mini-card-img img {
    color: transparent;
  }
</style>
