---
/**
 * TrustBar Component (Brands Index)
 * 3-item trust row: genuine products, manufacturer warranty, expert support.
 * Icons match BuyBox's trust grid for consistent meaning across the site.
 */
import Container from "../../components/ui/Container.astro";

const items = [
  {
    title: "100% Genuine Products",
    description: "Every product sourced directly from the manufacturer. No grey market, no replicas or imitations.",
  },
  {
    title: "Manufacturer Warranty",
    description: "Full international warranty honored in Pakistan. Local service center for repairs and maintenance.",
  },
  {
    title: "Expert Support & Training",
    description: "Free product training, installation assistance, and ongoing technical support for every purchase.",
  },
];
---

<section class="py-16 lg:py-20 border-t border-dark-border">
  <Container>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {items.map((item, i) => (
        <div
          class="flex flex-col items-center text-center gap-4 p-8 rounded-xl bg-dark-card border border-dark-border"
          data-reveal="up"
          style={`transition-delay: ${i * 100}ms;`}
        >
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary/15 text-primary" aria-hidden="true">
            {i === 0 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><polyline points="9 12 11 14 15 10" /></svg>
            )}
            {i === 1 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><path d="M9 15l2 2 4-4" /></svg>
            )}
            {i === 2 && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="8.5" cy="7" r="4" /><path d="M20 8v6M23 11h-6" /></svg>
            )}
          </div>
          <div>
            <h3 class="text-base font-semibold text-text-primary">{item.title}</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
